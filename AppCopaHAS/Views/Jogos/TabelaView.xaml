<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppCopaHAS.Views.Jogos.TabelaView"
             Title="TabelaView">
    <ScrollView>
        <VerticalStackLayout Padding="10,0,0,0">
            <CollectionView x:Name="listView" ItemsSource="{Binding Jogos}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="5" Padding="10" BackgroundColor="LightGray">
                            <VerticalStackLayout Spacing="8">
                                <Label FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" 
                                       Text="{Binding DataHora, StringFormat='{0:dd/MM/yyyy HH:mm}'}" />                                
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0" FontSize="18" Text="{Binding SelecaoMandante}" />
                                    <Label Grid.Column="1" FontSize="18" FontAttributes="Bold" Text="{Binding GolsMandante}" />
                                </Grid>                                
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0" FontSize="18" Text="{Binding SelecaoVisitante}" />
                                    <Label Grid.Column="1" FontSize="18" FontAttributes="Bold" Text="{Binding GolsVisitante}" />
                                </Grid>
                                <BoxView HeightRequest="1" />                                
                                <Label FontSize="14" Text="{Binding Estadio}" />
                                <Label FontSize="12" Text="{Binding Cidade}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>