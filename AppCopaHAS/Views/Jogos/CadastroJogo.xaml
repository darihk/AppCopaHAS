<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppCopaHAS.Views.Jogos.CadastroJogo"
             Title="CadastroJogo">
    <ScrollView>
        <VerticalStackLayout Spacing="3" Padding="15">
            <Label Text="Data" FontSize="Medium" />
            <DatePicker />
            <Label Text="Hora" FontSize="Medium" />
            <TimePicker />
            <Picker Title="---Estádio---" ItemsSource="{Binding Estadios}" ItemDisplayBinding="{Binding Nome}" />
            <HorizontalStackLayout>
                <Picker Title="---Seleção 1---" ItemsSource="{Binding Selecoes}"
ItemDisplayBinding="{Binding Pais}" />
                <Entry Text="" FontSize="Medium" Keyboard="Numeric"/>
            </HorizontalStackLayout>
            <HorizontalStackLayout>
                <Picker Title="---Seleção 2---" ItemsSource="{Binding Selecoes}"
ItemDisplayBinding="{Binding Pais}" />
                <Entry Text="" FontSize="Medium" Keyboard="Numeric"/>
            </HorizontalStackLayout>
            <HorizontalStackLayout Spacing="20">
                <Button Text="Salvar" Command="{Binding SalvarCommand}"></Button>
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>