<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppCopaHAS.Views.Jogadores.CadastroJogadorView"
             Title="CadastroJogadorView">
    <ScrollView>
        <VerticalStackLayout Spacing="3" Padding="15">
            <Picker Title="---Seleção---" SelectedItem="{Binding SelecaoSelecionada}"
                        ItemsSource="{Binding Selecoes}"
                        ItemDisplayBinding="{Binding Pais}"/>

            <Entry Text="{Binding Nome}" FontSize="Medium" Keyboard="Text"/>
            <Entry Text="{Binding Posicao}" FontSize="Medium" Keyboard="Text"/>
            <Entry Text="{Binding NumeroCamisa}" FontSize="Medium" Keyboard="Numeric"/>

            <Button Text="Salvar" Command="{Binding SalvarCommand}"></Button>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>